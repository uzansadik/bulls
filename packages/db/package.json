{
  "name": "@openbulls/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/*": "./src/schema/*",
    "./repositories": "./src/repositories/index.ts",
    "./repositories/*": "./src/repositories/*",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "build": "echo 'db is consumed via source'",
    "dev": "echo 'db is consumed via source'",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "studio": "drizzle-kit studio --config ./drizzle.config.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.7.2"
  }
}