{
  "name": "@openbulls/i18n",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    },
    "./messages/tr": {
      "default": "./messages/tr.json"
    },
    "./messages/en": {
      "default": "./messages/en.json"
    }
  },
  "files": ["dist", "messages", "src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "next-intl": "^3.26.3"
  },
  "peerDependencies": {
    "next": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "next": "^16.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
