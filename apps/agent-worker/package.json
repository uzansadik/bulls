{
  "name": "@openbulls/agent-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@langchain/langgraph": "latest",
    "@openbulls/agent-runtime": "workspace:*",
    "@openbulls/billing": "workspace:*",
    "@openbulls/config": "workspace:*",
    "@openbulls/db": "workspace:*",
    "@openbulls/jobs": "workspace:*",
    "@openbulls/logger": "workspace:*",
    "@openbulls/market-data": "workspace:*",
    "@openbulls/portfolio": "workspace:*",
    "@openbulls/shared": "workspace:*",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}