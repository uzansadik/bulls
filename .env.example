# Openbulls - env example
# Copy to .env (root) for scripts and to apps/*/.env.local for apps.

# ============================================================
# Common
# ============================================================
NODE_ENV=development

# ============================================================
# Database (Postgres)
# ============================================================
DATABASE_URL=postgres://openbulls:openbulls@localhost:5432/openbulls

# ============================================================
# Queue (Redis / BullMQ)
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# Better Auth
# ============================================================
BETTER_AUTH_SECRET=replace-with-32-char-random-secret-string
BETTER_AUTH_URL=http://localhost:3000

# ============================================================
# AI providers (any subset; Vercel AI Gateway preferred)
# ============================================================
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ============================================================
# Telegram bot (apps/telegram-bot)
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ============================================================
# Stripe (apps/web billing)
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=

# ============================================================
# Iyzico (apps/web billing - TR market)
# ============================================================
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com

# ============================================================
# Market data providers
# ============================================================
TWELVE_DATA_API_KEY=
YAHOO_FINANCE_API_KEY=
KAP_API_KEY=
TCMB_API_KEY=

# ============================================================
# Observability
# ============================================================
LOG_LEVEL=debug
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=